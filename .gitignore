# Python
__pycache__/
*.py[cod]
.venv/
venv/
env/
*.egg-info/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Secrets / config
.env
*.key
secrets.*
secrets/
*.pem
*.crt

# Output may hold large/generated artifacts — keep dir, ignore bulky contents by default
output/*
!output/.gitkeep

# Downloaded source data + built DB (large, regenerable).
# Root-anchored so it does NOT ignore app source under code/app/lib/data/.
/data/

# Receipt test images at repo root (internet-sourced, not ours to redistribute).
# Root-anchored so it does NOT ignore code/ocr_samples/pharm_*.json fixtures.
/pharm_*

# OCR benchmark — compiled Swift helper + downloaded model weights (regenerable).
# Source, adapters, and gold/ ARE tracked; the venv is covered by .venv/ above.
code/ocr_bench/.bin/
code/ocr_bench/models/

# Public repo: ignore internal docs/specs; keep only the root README (rewritten for the comp).
*.md
!/README.md
/pharmaceutical_invoice.jpeg
